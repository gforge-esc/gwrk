{
  "project": {
    "name": "gwrk",
    "slack": {
      "channelId": "C0AL99J34PP",
      "channelName": "gwrk-dev",
      "webhookUrl": "https://hooks.slack.com/services/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"
    }
  },
  "agents": {
    "define": "gemini",
    "implement": "gemini",
    "throttleMs": 15000,
    "registry": {
      "gemini": {
        "type": "local-cli",
        "command": "gemini",
        "discoveryMethod": "manual",
        "quotaProbe": {
          "method": "optimistic",
          "cacheTTLMinutes": 5
        },
        "maxConcurrent": 2,
        "models": [
          { "name": "gemini-2.5-pro", "tier": "thinking" },
          { "name": "gemini-2.5-flash", "tier": "fast" }
        ]
      },
      "claude": {
        "type": "local-cli",
        "command": "claude",
        "discoveryMethod": "manual",
        "quotaProbe": {
          "method": "optimistic",
          "cacheTTLMinutes": 5
        },
        "maxConcurrent": 1,
        "models": [
          { "name": "claude-sonnet-4", "tier": "thinking" }
        ],
        "fallback": "gemini"
      }
    },
    "fallbackOrder": ["gemini", "claude"]
  },
  "server": {
    "port": 18790,
    "host": "localhost",
    "heartbeatIntervalMs": 5000,
    "networkCheckIntervalMs": 30000
  },
  "parallelism": {
    "local": {
      "maxCpu": 80,
      "maxMem": 80,
      "minDiskGb": 10,
      "maxClones": 2
    },
    "cloud": {
      "maxConcurrent": 10
    }
  }
}

{
  "project": {
    "name": "gwrk",
    "type": "pnpm-monorepo",
    "stack": {
      "language": "TypeScript",
      "buildSystem": "pnpm"
    },
    "layout": "monorepo",
    "architecture": "Layered",
    "conventions": "TDD"
  },
  "server": {
    "port": 18790,
    "host": "localhost",
    "heartbeatIntervalMs": 5000,
    "networkCheckIntervalMs": 30000
  },
  "parallelism": {
    "local": {
      "maxCpu": 80,
      "maxMem": 80,
      "minDiskGb": 10,
      "maxClones": 2
    },
    "cloud": {
      "maxConcurrent": 10
    }
  }
}
{
  "name": "@gwrk/cli",
  "version": "1.2.0-alpha.0",
  "type": "module",
  "bin": {
    "gwrk": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gforge-esc/gwrk.git"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/ && cp src/slack-manifest.yml dist/ && mkdir -p dist/plugins/builtins && cp -r src/plugins/builtins/* dist/plugins/builtins/",
    "test": "vitest run",
    "test:ci": "GWRK_SKIP_INTEGRATION=1 vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:report": "tsx scripts/dev/test-report.ts",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^13.1.0",
    "dockerode": "^4.0.9",
    "fastify": "^5.8.1",
    "graphology": "0.25.4",
    "graphology-dag": "0.4.1",
    "graphology-generators": "0.11.2",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-traversal": "0.3.1",
    "sigma": "^3.0.3",
    "yaml": "^2.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@slack/types": "^2.20.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.13.5",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}

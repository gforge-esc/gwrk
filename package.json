{
  "name": "@gwrk/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "gwrk": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "commander": "^13.1.0",
    "dockerode": "^4.0.9",
    "fastify": "^5.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.13.5",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
